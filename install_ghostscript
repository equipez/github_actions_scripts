#!/usr/bin/env bash
# Usage: bash install_ghostscript

if [[ "$GITHUB_ACTIONS" != "true" || "$RUNNER_ENVIRONMENT" != "github-hosted" || "$RUNNER_OS" != "Linux" ]]; then
    echo ""
    echo "Warning: This script is intended to run only in GitHub-hosted Linux runners. Skip execution." >&2
    echo "It uses snap to install the latest version of ghostscript. If this is desirable, download the snap package and install it manually." >&2
    echo ""
    exit 0
fi

# Default version. This is the latest version as of 20220926. This should not matter if the "Find
# out the latest version" part works properly.
VER_DFT=10.0.0

# The installation may fail due to network issues, so we retry until it works. We retry for at most
# $RETRY_MAX times with a delay of $RETRY_DELAY_SECONDS seconds between attempts.
if [[ "$#" -ge 1 ]]; then
    RETRY_MAX="$1"
else
    RETRY_MAX=5
fi
if [[ "$#" -ge 2 ]]; then
    RETRY_DELAY_SECONDS="$2"
else
    RETRY_DELAY_SECONDS=10
fi

# Make a temp directory and move into it
TMP_DIR="$(mktemp -d)"
cleanup() {
    # Only remove if it still exists
    [[ -n "${TMP_DIR:-}" && -d "${TMP_DIR}" ]] && rm -rf -- "${TMP_DIR}"
    TMP_DIR=""  # Prevent double cleanup
}

trap cleanup EXIT

echo "--> Created temporary directory: ${TMP_DIR}"
cd "${TMP_DIR}" || exit 1
echo "--> Changed to ${TMP_DIR}"

# Create a custom curl wrapper to enforce HTTP/1.1 and IPv4, with retries and timeouts.
# Useful in CI environments with occasional network issues.
cat >"$TMP_DIR/curl" <<'EOF'
#!/usr/bin/env bash
exec /usr/bin/curl --http1.1 -4 -L -C - --retry 5 --retry-connrefused --retry-delay 5 --no-keepalive --limit-rate 50M --connect-timeout 30 --max-time 1800 "$@"
EOF
chmod +x "$TMP_DIR/curl"
export PATH="$TMP_DIR:$PATH"
type curl

# Find out the latest version.
RELEASE="https://www.ghostscript.com/releases/index.html"
WEBPG=index.html
wget "$RELEASE" -O "$WEBPG"
VER=$(grep "latest release" "$WEBPG" | grep -oE "([0-9]{1,}\.)+[0-9]{1,}")
if [[ -z "$VER" ]] ; then
    printf "\n\n******Fail to find the latest version.******\n******Will install the default version: %s******\n\n" "$VER_DFT"
    VER=$VER_DFT
fi
printf "\n\n******Version to install: %s******\n\n" "$VER"
VER_NO_DOT=${VER//\./}
VER_DFT_NO_DOT=${VER_DFT//\./}

# Download URL
PKG_NAME=gs_"${VER}"_amd64
URL=https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/gs"${VER_NO_DOT}"/"${PKG_NAME}"_snap.tgz
URL_DFT=https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/gs"${VER_DFT_NO_DOT}"/ghostscript-"${VER_DFT}"-linux-x86_64.tgz

TGZ=$TMP_DIR/gs.tgz

if curl -fL -o "${TGZ}" "${URL}" > /dev/null 2>&1 ; then
    tar zxvf "${TGZ}"
    ls -l "${PKG_NAME}"_snap/"${PKG_NAME}".snap
    sudo snap install --dangerous "${PKG_NAME}"_snap/"${PKG_NAME}".snap
else
    printf "******Failed to download the latest version.******\n******Will install the default version: %s******\n\n" "$VER_DFT"
    RETRY_TIMES=0
    while true; do
        if curl -fL -o "${TGZ}" "${URL_DFT}" > /dev/null 2>&1 ; then
            break
        fi
        RETRY_TIMES=$((RETRY_TIMES + 1))
        if [ $RETRY_TIMES -ge "$RETRY_MAX" ]; then
            echo "Error: Downloading failed after $RETRY_TIMES attempts." >&2
            exit 1
        else
            echo "Retrying in $RETRY_DELAY_SECONDS seconds ... (Attempt: $RETRY_TIMES)"
            rm -f -- "${TGZ}"
            sleep "$RETRY_DELAY_SECONDS"
        fi
    done

    GS="$(command -v gs)"
    if [[ -z "$GS" ]] ; then
        GS=/usr/bin/gs
    fi

    tar zxvf "$TGZ"
    NEWGS="ghostscript-$VER_DFT-linux-x86_64/gs-$VER_DFT_NO_DOT-linux-x86_64"

    if [[ -f "$GS" ]] ; then
        sudo cp "$GS" "$GS".bak
    fi
    sudo cp "$NEWGS" "$GS"
fi

gs -v
command -v gs
